<% content_for :title, "#{@employee.first_name} #{@employee.last_name}" %>

<h1 class="h3 fw-bold border-bottom border-primary pb-2 mb-4">Employee Details</h1>

<%= render @employee %>

<div class="d-flex gap-2 mt-2">
  <%= link_to "Edit", edit_employee_path(@employee), class: "btn btn-warning btn-sm" %>
  <%= link_to "Back to Employees", employees_path, class: "btn btn-secondary btn-sm" %>
  <%= button_to "Delete", @employee, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
</div>
