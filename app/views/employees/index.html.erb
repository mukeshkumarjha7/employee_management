<% content_for :title, "Employees" %>

<p style="color: green"><%= notice %></p>

<h1>Employees</h1>

<div id="employees">
  <% @employees.each do |employee| %>
    <%= render employee %>
    <p>
      <%= link_to "Show", employee %> |
      <%= link_to "Edit", edit_employee_path(employee) %> |
      <%= link_to "Delete", employee, method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </p>
    <hr>
  <% end %>
</div>

<%= link_to "New Employee", new_employee_path %>
