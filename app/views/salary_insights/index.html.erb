<% content_for :title, "Salary Insights" %>

<h1>Salary Insights</h1>

<div>
  <%= form_with url: salary_insights_path, method: :get do |form| %>
    <div>
      <%= form.label :country, "Country", style: "display: block" %>
      <%= form.text_field :country, value: @country, placeholder: "e.g. India" %>
    </div>

    <div>
      <%= form.label :job_title, "Job Title (optional)", style: "display: block" %>
      <%= form.text_field :job_title, value: @job_title, placeholder: "e.g. Software Engineer" %>
    </div>

    <div>
      <%= form.submit "Search" %>
    </div>
  <% end %>
</div>

<% if @insights %>
  <h2>Results</h2>

  <div>
    <p><strong>Country:</strong> <%= @country %></p>
  </div>

  <% if @job_title.present? %>
    <div>
      <p><strong>Job Title:</strong> <%= @job_title %></p>
    </div>
  <% end %>

  <div>
    <p><strong>Employees Count:</strong> <%= @insights[:employees_count] %></p>
  </div>

  <% if @insights[:employees_count] == 0 %>
    <div>
      <p>No employees found for the given search criteria.</p>
    </div>
  <% else %>
    <div>
      <p><strong>Min Salary:</strong> <%= @insights[:min_salary] %></p>
    </div>

    <div>
      <p><strong>Max Salary:</strong> <%= @insights[:max_salary] %></p>
    </div>

    <div>
      <p><strong>Average Salary:</strong> <%= @insights[:avg_salary] %></p>
    </div>
  <% end %>
<% end %>
